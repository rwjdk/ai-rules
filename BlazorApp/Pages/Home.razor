@using BlazorApp.Data
@attribute [Route(PageRoutes.Home)]

<PageTitle>Todo App</PageTitle>

<MudStack Spacing="4" Class="todo-page">
    <MudPaper Class="hero-panel pa-6">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
            <div>
                <MudText Typo="Typo.h3">Todo App</MudText>
            </div>
            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled" Icon="@Icons.Material.Filled.FormatListBulleted">
                    @($"{TotalCount} total")
                </MudChip>
                <MudChip T="string" Color="Color.Warning" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.PendingActions">
                    @($"{OpenCount} open")
                </MudChip>
                <MudChip T="string" Color="Color.Success" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.TaskAlt">
                    @($"{CompletedCount} completed")
                </MudChip>
            </MudStack>
        </MudStack>
    </MudPaper>

    <MudPaper Class="pa-4 list-panel">
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap">
            <div>
                <MudText Typo="Typo.h5">Tasks</MudText>
            </div>

            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           Disabled="@IsSaving"
                           OnClick="@OpenCreateDialogAsync">
                    New task
                </MudButton>

                <MudButton Variant="Variant.Text"
                           StartIcon="@Icons.Material.Filled.Refresh"
                           Disabled="@IsLoading"
                           OnClick="@LoadTodosAsync">
                    Refresh
                </MudButton>
            </MudStack>
        </MudStack>

        @if (IsLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="my-4" />
        }

        <MudDataGrid T="TodoItem"
                     @ref="TodoGrid"
                     Items="@Todos"
                     ReadOnly="false"
                     EditMode="DataGridEditMode.Form"
                     EditTrigger="DataGridEditTrigger.Manual"
                     EditDialogOptions="@TodoDialogOptions"
                     Hover="true"
                     Dense="true"
                     Striped="true"
                     Class="mt-4"
                     CommittedItemChanges="CommitItemChangesAsync"
                     CanceledEditingItem="HandleCanceledEditingItem">
            <Columns>
                <PropertyColumn Property="x => x.Title" Title="Title">
                    <EditTemplate>
                        <MudTextField T="string"
                                      Label="Title"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Required="true"
                                      @bind-Value="context.Item.Title" />
                    </EditTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.StartDate" Title="Start" Format="yyyy-MM-dd">
                    <EditTemplate>
                        <MudDatePicker Label="Start date"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Editable="true"
                                       DateFormat="yyyy-MM-dd"
                                       Date="@context.Item.StartDate"
                                       DateChanged="@(date => context.Item.StartDate = date ?? DateTime.Today)" />
                    </EditTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.DueDate" Title="Due" Format="yyyy-MM-dd">
                    <EditTemplate>
                        <MudDatePicker Label="Due date"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Editable="true"
                                       DateFormat="yyyy-MM-dd"
                                       Date="@context.Item.DueDate"
                                       DateChanged="@(date => context.Item.DueDate = date ?? DateTime.Today)" />
                    </EditTemplate>
                </PropertyColumn>

                <PropertyColumn Property="x => x.Completed" Title="Status">
                    <CellTemplate>
                        <MudChip T="string"
                                 Color="@(context.Item.Completed ? Color.Success : Color.Warning)"
                                 Variant="Variant.Outlined"
                                 Size="Size.Small">
                            @(context.Item.Completed ? "Completed" : "Open")
                        </MudChip>
                    </CellTemplate>
                    <EditTemplate>
                        <MudCheckBox T="bool"
                                     Color="Color.Primary"
                                     Label="Completed"
                                     @bind-Value="context.Item.Completed" />
                    </EditTemplate>
                </PropertyColumn>

                <TemplateColumn Title="Actions" Sortable="false" Filterable="false" CellClass="actions-cell">
                    <CellTemplate>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       OnClick="@(() => OpenEditDialogAsync(context.Item))" />
                        <MudIconButton Icon="@(context.Item.Completed? Icons.Material.Filled.RadioButtonUnchecked : Icons.Material.Filled.CheckCircle)"
                                       Color="@(context.Item.Completed ? Color.Warning : Color.Success)"
                                       Size="Size.Small"
                                       OnClick="@(() => ToggleCompletedAsync(context.Item))" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       OnClick="@(() => DeleteTodoAsync(context.Item.Id, context.Item.Title))" />
                    </CellTemplate>
                </TemplateColumn>
            </Columns>

            <NoRecordsContent>
                <MudText Typo="Typo.body1" Class="empty-state">
                    No todos yet. Use the New task button to create the first one.
                </MudText>
            </NoRecordsContent>

            <PagerContent>
                <MudDataGridPager T="TodoItem" />
            </PagerContent>
        </MudDataGrid>
    </MudPaper>
</MudStack>
